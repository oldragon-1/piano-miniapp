/* 预览页 - 暖橘色主题（与首页一致） */
page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #FFF8F0;
}

.container {
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 顶部信息条 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #FF8C00, #FFA500);
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(255, 140, 0, 0.2);
}

.song-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.1);
}

.speed-control {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.speed-label { font-size: 22rpx; color: rgba(255,255,255,0.8); }

.speed-btn {
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
  background: rgba(255,255,255,0.25);
  color: #fff;
}

.speed-btn.active {
  background: #fff;
  color: #E86A00;
  font-weight: bold;
}

/* 曲谱区 */
.sheet-area {
  flex: 0 0 55%;
  padding: 10rpx 24rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #FFF8F0, #FFEEDD);
  min-height: 0;
}

.sheet-scroll { height: 100%; }

.sheet-list { padding: 4rpx 0; }

.sheet-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 24rpx;
  margin-bottom: 4rpx;
  border-radius: 8rpx;
  background: #fff;
  min-height: 44rpx;
  box-shadow: 0 1rpx 4rpx rgba(255, 140, 0, 0.08);
}

.sheet-row.active {
  background: #FFF8E1;
  border: 2rpx solid #F5C342;
  box-shadow: 0 0 16rpx rgba(245, 195, 66, 0.3);
  transform: scale(1.02);
}

.sheet-row.played { opacity: 0.35; }

.note-num {
  font-size: 28rpx;
  font-weight: bold;
  color: #E86A00;
}

.sheet-row.active .note-num { color: #F5C342; font-size: 36rpx; }

.note-chord {
  font-size: 20rpx;
  color: #B8860B;
}

.sheet-row.active .note-chord { color: #87CEEB; font-weight: bold; }

.note-hand {
  font-size: 14rpx;
  color: #FFD4A0;
  min-width: 20rpx;
  text-align: center;
}

.sheet-row.active .note-hand { color: #E86A00; }

/* 键盘区 */
.keyboard-area {
  flex: 0 0 30%;
  width: 100vw;
  overflow: hidden;
  background: #FFF5E6;
}

/* 底部按钮 */
.bottom-bar {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 10rpx 24rpx 14rpx;
  flex-shrink: 0;
  background: linear-gradient(0deg, #FFF0E0, #FFF8F0);
  border-top: 1rpx solid #FFD4A0;
}

.btn-play-demo {
  background: #FFF5E6;
  color: #E86A00;
  padding: 14rpx 32rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  text-align: center;
  min-width: 200rpx;
  font-weight: bold;
  border: 1rpx solid #FFD4A0;
}

.btn-play-demo.playing {
  background: linear-gradient(135deg, #FF8C00, #E86A00);
  color: #fff;
  border: none;
}

.btn-start {
  background: linear-gradient(135deg, #FF8C00, #E86A00);
  color: #fff;
  padding: 14rpx 48rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(255, 140, 0, 0.3);
}
