page {
  background: #FFF8F0;
}

.container {
  min-height: 100vh;
  padding: 0 24rpx 120rpx;
}

.header {
  padding: 20rpx 0 16rpx;
  text-align: center;
}

.subtitle {
  font-size: 24rpx;
  color: #B8860B;
  display: block;
}

/* 每日推荐卡片 */
.daily-card {
  background: linear-gradient(135deg, #FF8C00, #FFA500);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  position: relative;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 0, 0.3);
}

.card-badge {
  display: inline-block;
  background: rgba(255,255,255,0.25);
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 14rpx;
  border-radius: 20rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.card-body {
  /* 内容区 */
}

.card-main-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.card-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
  flex-shrink: 0;
}

.card-difficulty {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-right: auto;
}

.card-play-btn {
  background: #fff;
  color: #E86A00;
  padding: 10rpx 28rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.card-play-btn:active {
  background: #FFF5E6;
}

.card-tags {
  display: flex;
  gap: 8rpx;
}

.tag {
  font-size: 20rpx;
  padding: 3rpx 10rpx;
  background: rgba(255,255,255,0.3);
  color: #fff;
  border-radius: 8rpx;
}

.diff-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 8rpx;
  display: inline-block;
}

.diff-dot.green { background: #2ecc71; }
.diff-dot.orange { background: #FFF; }

/* 主按钮 */
.main-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.action-card {
  flex: 1;
  background: linear-gradient(135deg, #FFF5E6, #FFE4C4);
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 140, 0, 0.15);
  border: 1rpx solid #FFD4A0;
}

.action-card:active {
  background: linear-gradient(135deg, #FFE4C4, #FFC88A);
}

.action-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 12rpx;
}

.action-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #E86A00;
  display: block;
  margin-bottom: 8rpx;
}

.action-desc {
  font-size: 22rpx;
  color: #B8860B;
  display: block;
}

/* 曲库列表 */
.song-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 140, 0, 0.1);
  border: 1rpx solid #FFE4C4;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #E86A00;
}

.search-box {
  background: #FFF5E6;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  border: 1rpx solid #FFD4A0;
}

.search-input {
  font-size: 24rpx;
  width: 200rpx;
  color: #E86A00;
}

.search-input::placeholder {
  color: #D4A060;
}

.tag-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  background: #FFF5E6;
  color: #B8860B;
  border-radius: 8rpx;
  border: 1rpx solid #FFD4A0;
}

.tag.active {
  background: linear-gradient(135deg, #FF8C00, #FFA500);
  color: #fff;
  border: 1rpx solid transparent;
}

.song-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #FFE4C4;
}

.song-item:last-child {
  border-bottom: none;
}

.song-name {
  font-size: 28rpx;
  color: #E86A00;
  font-weight: 500;
}

.song-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.song-meta {
  margin-top: 8rpx;
  display: flex;
  gap: 8rpx;
}

.song-tag {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  background: #FFF5E6;
  color: #B8860B;
  border-radius: 6rpx;
  border: 1rpx solid #FFD4A0;
}

.song-arrow {
  font-size: 36rpx;
  color: #FFA500;
}

.song-actions-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.btn-notation-sm {
  font-size: 20rpx;
  color: #E86A00;
  padding: 4rpx 12rpx;
  border: 1rpx solid #FFD4A0;
  border-radius: 6rpx;
}

/* 查看更多 */
.load-more {
  text-align: center;
  padding: 24rpx 0;
}

.load-more-text {
  font-size: 26rpx;
  color: #E86A00;
  font-weight: bold;
  padding: 12rpx 40rpx;
  background: #FFF5E6;
  border-radius: 20rpx;
  border: 1rpx solid #FFD4A0;
}

/* 简谱弹窗 */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.notation-modal {
  background: #FFFAF0;
  border-radius: 20rpx;
  width: 85%;
  max-height: 75vh;
  display: flex;
  flex-direction: column;
  border: 2rpx solid #FFD4A0;
  overflow: hidden;
}

.notation-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #FFE4C4;
}

.notation-modal-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #E86A00;
}

.notation-modal-close {
  font-size: 32rpx;
  color: #B8860B;
  padding: 8rpx;
}

.notation-modal-body {
  flex: 1;
  padding: 24rpx 30rpx;
  max-height: 60vh;
}

.notation-line {
  margin-bottom: 16rpx;
}

.notation-text {
  font-size: 32rpx;
  color: #5C3D1A;
  font-family: 'Courier New', monospace;
  letter-spacing: 4rpx;
  line-height: 1.8;
}

/* 底部导航 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: linear-gradient(180deg, #FFF8F0, #FFF0E0);
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -4rpx 12rpx rgba(255, 140, 0, 0.15);
  border-top: 1rpx solid #FFE4C4;
  z-index: 50;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 40rpx;
}

.tab-item.active .tab-icon,
.tab-item.active .tab-label {
  color: #E86A00;
}

.tab-icon {
  font-size: 36rpx;
  color: #B8860B;
}

.tab-label {
  font-size: 20rpx;
  color: #B8860B;
  margin-top: 4rpx;
}
