/* 弹奏页 - 横向简谱 + 全宽键盘（橙色主题） */
page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #F4F1DE;
}

.container {
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 上半屏 */
.top-area {
  flex:1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  overflow: visible;
}

/* 顶部信息条 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #FF8C00, #E86A00);
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(255, 140, 0, 0.25);
}

.song-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #fff;
}

.speed-control {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(255,255,255,0.25);
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.speed-btn { font-size: 22rpx; }

.speed-text {
  font-size: 18rpx;
  color: #fff;
  min-width: 60rpx;
  text-align: center;
  font-weight: bold;
}

/* 自动播放按钮 */
.auto-play-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: rgba(255,255,255,0.3);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 6rpx;
}

.auto-play-btn.playing {
  background: rgba(255, 60, 60, 0.4);
}

.auto-play-icon {
  font-size: 20rpx;
  color: #fff;
}

.auto-play-label {
  font-size: 18rpx;
  color: #fff;
  font-weight: bold;
}

.score-display {
  font-size: 20rpx;
  color: #fff;
  font-weight: bold;
}

/* 简谱区：左(和弦提示,7/17宽) + 右(简谱滚动,10/17宽)，对齐键盘左右手区域 */
.notation-area {
  flex:1;
  min-height: 0;
  display: flex;
  align-items: stretch;
  background: linear-gradient(180deg, #F4F1DE, #E8D5B0);
  overflow: visible;
}

/* 左侧和弦提示区 - 对齐键盘左手区(7/17≈41.18%宽) */
.chord-hint {
  flex: 0 0 41.18%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.chord-hint-empty {
  flex: 0 0 41.18%;
  box-sizing: border-box;
}

.chord-label {
  font-size: 18rpx;
  color: #FF8C00;
  margin-bottom: 4rpx;
}

.chord-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF8C00;
}

/* 右侧简谱滚动区 - 对齐键盘右手区(10/17≈58.82%宽) */
/* scroll-view 带 scroll-x 是原生组件，不尊重 flex:1，必须显式设宽度 */
.notation-scroll {
  flex: 0 0 58.82%;
  white-space: nowrap;
  overflow: visible;
}

.notation-track {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 8rpx 8rpx;
  height: 100%;
  box-sizing: border-box;
}

.note-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 56rpx;
  padding: 18rpx 0 10rpx;
  margin: 0 4rpx;
  text-align: center;
  transition: all 0.25s ease-out;
  position: relative;
}

/* 高音点标记（数字上方） */
.note-dot-high {
  font-size: 14rpx;
  font-weight: bold;
  color: #bbb;
  line-height: 0.8;
  display: block;
  margin-bottom: -8rpx;
}

.note-item.active .note-dot-high {
  color: #FF8C00;
  text-shadow: 0 0 12rpx rgba(255, 140, 0, 0.4);
}

.note-item.done .note-dot-high {
  color: #C8B8A0;
}

/* 低音点标记（数字下方） */
.note-dot-low {
  font-size: 14rpx;
  font-weight: bold;
  color: #bbb;
  line-height: 1;
  display: block;
  margin-top: 2rpx;
}

.note-item.active .note-dot-low {
  color: #FF8C00;
  text-shadow: 0 0 12rpx rgba(255, 140, 0, 0.4);
}

.note-item.done .note-dot-low {
  color: #C8B8A0;
}

.note-item.active {
  transform: scale(1.2);
}

.note-item.done {
  opacity: 0.45;
}

.note-num {
  font-size: 28rpx;
  font-weight: bold;
  color: #888;
  line-height: 1;
  display: block;
}

.note-item.active .note-num {
  color: #FF8C00;
  font-size: 40rpx;
  text-shadow: 0 0 12rpx rgba(255, 140, 0, 0.4), 0 0 24rpx rgba(255, 140, 0, 0.15);
}

.note-item.done .note-num {
  color: #C8B8A0;
}

/* 已弹过的音符可点击回跳 */
.note-item.clickable {
  cursor: pointer;
}

/* 底部进度行（对齐键盘左手41.18%/右手58.82%分区） */
.bottom-bar {
  padding: 4rpx 0 6rpx;
  background: rgba(255, 140, 0, 0.06);
  flex-shrink: 0;
}

.bottom-row {
  display: flex;
  align-items: center;
}

.bl-left {
  flex: 0 0 41.18%;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 8rpx;
  box-sizing: border-box;
}

.bl-right {
  flex: 0 0 58.82%;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 0 12rpx 0 4rpx;
  box-sizing: border-box;
}

.nav-btn {
  font-size: 28rpx;
  color: #FF8C00;
  opacity: 0.7;
  padding: 4rpx 8rpx;
  flex-shrink: 0;
  line-height: 1;
}

.progress-wrap {
  flex: 1;
  min-width: 0;
}

.progress-bar {
  width: 100%;
  height: 4rpx;
  background: #E8D5B0;
  border-radius: 2rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF8C00, #E86A00);
  transition: width 0.3s;
}

.progress-text {
  font-size: 14rpx;
  color: #FF8C00;
  opacity: 0.6;
  flex-shrink: 0;
}

/* 下半屏：全宽键盘 - 占屏幕高度 45% */
.keyboard-area {
  flex: 0 0 45%;
  width: 100vw;
  position: relative;
  background: #FFFFF5;
  overflow: hidden;
}

/* 成绩弹窗 */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(255, 140, 0, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.score-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  min-width: 360rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 140, 0, 0.25);
  border: 2rpx solid #E8D5B0;
}

.score-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF8C00;
  margin-bottom: 28rpx;
  display: block;
}

.score-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #E8D5B0;
}

.score-label { font-size: 24rpx; color: #FF8C00; }
.score-value { font-size: 26rpx; font-weight: bold; color: #FF8C00; }

.score-actions {
  margin-top: 28rpx;
  display: flex;
  gap: 16rpx;
}

.btn-primary {
  flex: 1;
  background: linear-gradient(135deg, #FF8C00, #E86A00);
  color: #fff;
  padding: 18rpx;
  border-radius: 10rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: bold;
}

.btn-secondary {
  flex: 1;
  background: #F4F1DE;
  color: #FF8C00;
  padding: 18rpx;
  border-radius: 10rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: bold;
  border: 1rpx solid #E8D5B0;
}
