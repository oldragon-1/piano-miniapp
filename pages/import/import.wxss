page {
  background: #FFF8F0;
}

.container {
  min-height: 100vh;
  padding: 30rpx 24rpx;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #E86A00;
  display: block;
}

.desc {
  font-size: 24rpx;
  color: #B8860B;
  margin-top: 8rpx;
  display: block;
}

.input-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 140, 0, 0.1);
  border: 1rpx solid #FFE4C4;
}

.title-section {
  padding: 16rpx 20rpx;
}

.input-label {
  font-size: 24rpx;
  color: #B8860B;
  margin-bottom: 8rpx;
  display: block;
}

.title-input {
  font-size: 30rpx;
  color: #E86A00;
  font-weight: 500;
}

.notation-input {
  width: 100%;
  min-height: 200rpx;
  font-size: 32rpx;
  font-family: monospace;
  color: #E86A00;
}

.notation-input::placeholder {
  color: #D4A060;
}

.options-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 140, 0, 0.1);
  border: 1rpx solid #FFE4C4;
}

.option-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #FFE4C4;
}

.option-row:last-child {
  border-bottom: none;
}

.option-label {
  font-size: 28rpx;
  color: #E86A00;
  font-weight: 500;
}

.picker-value {
  font-size: 28rpx;
  color: #FF8C00;
}

.action-section {
  margin-bottom: 20rpx;
}

.btn-transform {
  background: linear-gradient(180deg, #FF8C00, #E86A00);
  color: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(232, 106, 0, 0.3);
}

.result-section {
  background: linear-gradient(135deg, #FFF5E6, #FFE4C4);
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  border: 1rpx solid #FFD4A0;
}

.result-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #E86A00;
  margin-bottom: 20rpx;
  display: block;
}

.info-text {
  font-size: 26rpx;
  color: #B8860B;
  display: block;
  margin-bottom: 20rpx;
}

.result-btns {
  display: flex;
  gap: 16rpx;
}

.btn-play {
  flex: 1;
  background: linear-gradient(180deg, #FF8C00, #E86A00);
  color: #fff;
  padding: 20rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(232, 106, 0, 0.3);
}

.btn-preview {
  flex: 1;
  background: #FFF5E6;
  color: #E86A00;
  padding: 20rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  border: 1rpx solid #FFD4A0;
}

/* 版权弹窗 */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(232, 106, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  width: 560rpx;
  max-height: 70vh;
  overflow-y: auto;
  border: 2rpx solid #FFE4C4;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #E86A00;
  display: block;
  margin-bottom: 20rpx;
  text-align: center;
}

.modal-text {
  font-size: 26rpx;
  color: #B8860B;
  line-height: 1.6;
  display: block;
  margin-bottom: 30rpx;
  white-space: pre-wrap;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.btn-cancel {
  flex: 1;
  background: #FFF5E6;
  color: #B8860B;
  padding: 20rpx;
  border-radius: 10rpx;
  text-align: center;
  font-size: 28rpx;
  border: 1rpx solid #FFD4A0;
}

.btn-confirm {
  flex: 1;
  background: linear-gradient(180deg, #FF8C00, #E86A00);
  color: #fff;
  padding: 20rpx;
  border-radius: 10rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(232, 106, 0, 0.3);
}
